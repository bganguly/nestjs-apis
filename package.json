{
  "name": "nestjs-apis",
  "version": "1.0.0",
  "description": "A focused collection for NestJS API interview-prep projects.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "ts-node src/main.ts",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "create:table": "ts-node scripts/create-products-table.ts",
    "seed:synthetic": "ts-node scripts/seed-synthetic-products.ts",
    "import:csv": "ts-node scripts/import-products-csv.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bganguly/nestjs-apis.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/bganguly/nestjs-apis/issues"
  },
  "homepage": "https://github.com/bganguly/nestjs-apis#readme",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1029.0",
    "@aws-sdk/lib-dynamodb": "^3.1029.0",
    "@faker-js/faker": "^10.4.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parse": "^6.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
